<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </Console>

        <RollingFile name="AppFile"
                     fileName="var/logs/app.log"
                     filePattern="var/logs/app-%i.log.gz">

            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>

            <Filters>
                <ThresholdFilter level="error" onMatch="DENY" onMismatch="ACCEPT"/>
            </Filters>

            <Policies>
                <SizeBasedTriggeringPolicy size="50KB"/>
            </Policies>

            <DefaultRolloverStrategy max="7"/>
        </RollingFile>

        <RollingFile name="ErrorFile"
                     fileName="var/logs/error.log"
                     filePattern="var/logs/error-%i.log.gz">

            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>

            <Filters>
                <ThresholdFilter level="error" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>

            <Policies>
                <SizeBasedTriggeringPolicy size="50KB"/>
            </Policies>

            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AppFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Root>
    </Loggers>
</Configuration>